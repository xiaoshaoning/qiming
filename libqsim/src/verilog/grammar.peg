ATTR_OPEN     <- "(*" spacing
ATTR_CLOSE    <- "*)" spacing
PLUSCOLON     <- "+:" spacing
MINUSCOLON    <- "-:" spacing

ID <- < [a-zA-Z_$] [a-zA-Z0-9_$]* > spacing
# sized constants: <width>'<base><digits> or plain decimal
# ? and Z/z for casez don't-care, X/x for casex
NUMBER <- < ( digit+ "'" [sS]? [bBdDoOhH] [0-9a-fA-F_?ZzXx]+ / digit+ ) > spacing
STRING <- '"' < ( !'"' . )* > '"' spacing

LPAREN    <- '(' spacing
RPAREN    <- ')' spacing
LBRACKET  <- '[' spacing
RBRACKET  <- ']' spacing
LBRACE    <- '{' spacing
RBRACE    <- '}' spacing
SEMI      <- ';' spacing
COMMA     <- ',' spacing
DOT       <- '.' spacing
COLON     <- ':' spacing
QUESTION  <- '?' spacing
AT        <- '@' spacing
HASH      <- '#' spacing

ASSIGN    <- '=' !'=' spacing
ARROW     <- "->" spacing
PATT_SEP  <- "=>" spacing
PLUS      <- '+' spacing
MINUS     <- '-' spacing
FULL_SEP  <- "*>" spacing
STAR      <- '*' spacing
SLASH     <- '/' spacing
PERCENT   <- '%' spacing
AND       <- '&' !'&' spacing
OR        <- '|' !'|' spacing
XOR       <- '^' spacing
TILDE     <- '~' spacing

EQ        <- '==' spacing
NEQ       <- '!=' spacing
LE        <- '<=' spacing
GE        <- '>=' spacing
SHL       <- '<<' spacing
ASR       <- '>>>' spacing
SHR       <- '>>' spacing
LAND      <- '&&' spacing
LOR       <- '||' spacing
LNOT      <- '!' !'=' spacing

LT        <- '<' !( '=' / '<' ) spacing
GT        <- '>' !( '=' / '>' ) spacing

spacing       <- ( [ \t\r\n] / line_comment / block_comment )*
line_comment  <- "//" ( !'\n' . )*
block_comment <- "/*" ( !"*/" . )* "*/"
alnum         <- [a-zA-Z0-9_$]
digit         <- [0-9]
